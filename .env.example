# Compose-level config for docker-compose.yml. Copy to `.env` and fill in.
# (Backend runtime secrets live separately in backend/.env — see backend/.env.example.)

# Cloudflare Tunnel connector token.
# Zero Trust > Networks > Tunnels > (your tunnel) > Install connector → copy the
# token from the `--token` value.
TUNNEL_TOKEN=

# Frontend build-time values. PUBLIC — these get baked into the SPA bundle and
# are safe to expose (the Supabase anon key is meant for browsers).
VITE_SUPABASE_URL=https://dkbbhbpluvtimzzyavyg.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=https://rag.jungholee.com/api
